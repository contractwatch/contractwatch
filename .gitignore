launchd/com.contractwatch.plist

# Bulk USASpending archive zips (download fresh from files.usaspending.gov)
data/archives/

# HTTP cache (regenerated by scanner on demand)
cache/

# Local logs (bulk loader stdout, agent verification outputs)
logs/

# Generated dashboard data (rebuild via export_json.py)
web/data/

# Stale .bak files left by past sed edits
engine/*.bak-*
*.bak

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
