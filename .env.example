# ContractWatch environment configuration
#
# All env vars below are OPTIONAL. The codebase calls no external services
# that require keys. USASpending's public API needs no authentication; the
# bulk archive downloads work over plain HTTPS.
#
# Copy this file to .env if you want to set overrides for local runs.
# .env is gitignored, so your local values stay out of the repo.


# Pipe-delimited list of awarding agencies to skip at ingestion time and
# strip from flagged results at reflag time. Leave empty (default) to
# include every agency. Match the agency string exactly as it appears on
# USASpending (e.g. "Department of Health and Human Services").
# Example:
#   CONTRACTWATCH_EXCLUDED_AGENCIES=Department of Health and Human Services|Department of Veterans Affairs
CONTRACTWATCH_EXCLUDED_AGENCIES=

# Daily catch-up scan window. The scanner pulls awards whose last_modified
# date falls within the trailing N days from today, then upserts them.
# Default 2 days catches anything published in the last day plus a buffer
# for upstream reporting lag.
CONTRACTWATCH_BACKFILL_DAYS=2

# Cloudflare Pages project name for `wrangler pages deploy` invoked by
# daily_scan.sh. Set this to your own project if you deploy your own copy.
CONTRACTWATCH_CF_PROJECT=contractwatch
